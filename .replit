modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8096
externalPort = 5000

[[ports]]
localPort = 8097
externalPort = 4200

[[ports]]
localPort = 8098
externalPort = 3003

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 19881
externalPort = 3000

# Copy this file to `.env` and fill in your values, then run:
#   docker compose up -d
#
# `.env` is gitignored, so your real secrets stay out of version control and
# `git pull` will never conflict on them. This `.env.example` is safe to commit
# and serves as the documented list of every supported variable.

# ── Optional: JWT secret ──────────────────────────────────────
# Provide your own strong secret. If unset, the server auto-generates one
# and persists it in the /data volume on first run.
# JWT_SECRET=

# ── Optional: host port ───────────────────────────────────────
# The app always listens on 3000 inside the container; this only changes the
# host port mapping.
# PORT=3000

# ── Optional: TrueNAS SCALE ───────────────────────────────────
# TRUENAS_URL=http://your-truenas-ip
# TRUENAS_API_KEY=your-truenas-api-key

# ── Optional: Media Server (Plex or Jellyfin) ─────────────────
# MEDIA_SERVER_TYPE=jellyfin   # or "plex"
# MEDIA_SERVER_URL=http://your-media-server:8096
# MEDIA_SERVER_API_KEY=your-api-key

# ── Optional: Sonarr ──────────────────────────────────────────
# SONARR_URL=http://your-sonarr:8989
# SONARR_API_KEY=your-sonarr-api-key

# ── Optional: Radarr ──────────────────────────────────────────
# RADARR_URL=http://your-radarr:7878
# RADARR_API_KEY=your-radarr-api-key

# ── Optional: qBittorrent ─────────────────────────────────────
# QBITTORRENT_URL=http://your-qbittorrent:8080
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=your-qbittorrent-password

# ── Optional: Pi-hole ─────────────────────────────────────────
# PIHOLE_URL=http://your-pihole
# PIHOLE_API_KEY=your-pihole-api-token

# ── Optional: Nginx Proxy Manager ─────────────────────────────
# NPM_URL must point at the ADMIN/API port (81 by default), NOT the
# proxied site on 80/443.
# NPM_URL=http://your-npm-host:81
# NPM_EMAIL=admin@example.com
# NPM_PASSWORD=your-npm-admin-password
